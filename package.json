{
  "name": "telegram-miniapp-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "web:dev": "node ./scripts/serve-with-logs.mjs",
    "backend:dev": "node ./apps/backend/server.mjs",
    "db:migrate": "node ./scripts/db-migrate.mjs",
    "serve:logs": "node ./scripts/serve-with-logs.mjs",
    "simulate:battle": "node ./scripts/simulate-battle-run.mjs",
    "simulate:battle:smoke": "node ./scripts/simulate-battle-run.mjs --smoke",
    "analyze:telemetry": "node ./scripts/analyze-telemetry.mjs",
    "preview:mobile": "bash ./scripts/preview-mobile.sh",
    "capture:mobile": "node ./scripts/capture-mobile.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "playwright": "^1.55.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
